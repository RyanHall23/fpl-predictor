# FPL Predictor Backend Environment Variables

# Port (auto-provided by Render; defaults to 5000 locally)
PORT=5000

# PostgreSQL connection string (REQUIRED in production)
# Render PostgreSQL: Set to the internal connection string provided by Render
# Local development: postgresql://localhost:5432/fplpredictor
DATABASE_URL=postgresql://localhost:5432/fplpredictor

# JWT Secret (REQUIRED in production)
# Default: 'changeme' (development only)
# Production: Use a strong, random secret
JWT_SECRET=changeme

# Frontend URL for CORS (REQUIRED in production)
# Set to your deployed Render Static Site URL, e.g. https://your-app.onrender.com
# Local development: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# FPL API Mode
# 'true' (default): Use real FPL API from fantasy.premierleague.com
# 'false': Use local mock data from backend/mockData/ for testing
USE_FPL_API=true

# Expected Points Calculation
# 'true' (default): Use computed expected points from ML model
# 'false': Use raw API expected points
USE_COMPUTED_EP=true

# Manager Placeholders
# 'true': Include manager placeholders in squads
# 'false' (default): Do not include managers
INCLUDE_MANAGERS=false
