# FPL Predictor Backend Environment Variables

# Port for local development (defaults to 5000)
# Note: This is not used in Vercel serverless deployments
PORT=5000

# Frontend URL for CORS (REQUIRED in production)
# Set to your deployed Vercel URL, e.g. https://your-app.vercel.app
# Local development: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# FPL API Mode
# 'true' (default): Use real FPL API from fantasy.premierleague.com
# 'false': Use local mock data from backend/mockData/ for testing
USE_FPL_API=true

# Expected Points Calculation
# 'true' (default): Use computed expected points from ML model
# 'false': Use raw API expected points
USE_COMPUTED_EP=true

# Manager Placeholders
# 'true': Include manager placeholders in squads
# 'false' (default): Do not include managers
INCLUDE_MANAGERS=false

# PostgreSQL connection string (REQUIRED for auth/account features)
# Local development: postgresql://localhost:5432/fplpredictor
# Production: your Vercel Postgres / Supabase / Neon connection string
DATABASE_URL=postgresql://localhost:5432/fplpredictor

# JWT secret used to sign and verify auth tokens (REQUIRED for auth features)
# Use a long, random, hard-to-guess string in production
JWT_SECRET=changeme

# FPL Predictor's Team — managed team ID
# Set this after Gameweek 1 to enable the autonomous team tracking feature.
# The value is your FPL team ID (found in the URL on the FPL website).
# Without this variable the feature will continue showing the pre-season
# generated squad but will disable recommendation generation.
# APPLICATION_TEAM=
