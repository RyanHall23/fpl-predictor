{
  "name": "fpl-predictor-root",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently \"npm run start-backend\" \"npm run start-frontend\"",
    "build": "npm run build -w frontend",
    "start-backend": "npm start -w backend",
    "start-frontend": "npm start -w frontend",
    "test": "npm test -w frontend",
    "clean": "bash clean.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5"
  },
  "dependencies": {
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "prop-types": "^15.8.1",
    "react": "^19.2.4"
  }
}
